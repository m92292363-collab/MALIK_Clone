async function adminLogin() {
    const adminId = document.getElementById('admin-id-input').value.trim();
    const password = document.getElementById('admin-pass-input').value.trim();
    const btn = document.getElementById('adminLoginBtn');
    const errorEl = document.getElementById('admin-login-error');
    errorEl.classList.remove('show');
    if (!adminId || !password) {
        errorEl.textContent = 'Please enter Admin ID and Password';
        errorEl.classList.add('show'); return;
    }
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Verifying...';
    try {
        const res = await fetch('/api/admin-login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ adminId, password })
        });
        const data = await res.json();
        if (data.success) {
            closeAdminModal();
            document.getElementById('adminDashboard').classList.add('active');
            document.body.style.overflow = 'hidden';
        } else {
            errorEl.textContent = data.error || 'Incorrect credentials. Please try again.';
            errorEl.classList.add('show');
            document.getElementById('admin-id-input').classList.add('shake');
            document.getElementById('admin-pass-input').classList.add('shake');
            setTimeout(() => {
                document.getElementById('admin-id-input').classList.remove('shake');
                document.getElementById('admin-pass-input').classList.remove('shake');
            }, 500);
        }
    } catch(err) {
        errorEl.textContent = 'Connection error. Please try again.';
        errorEl.classList.add('show');
    }
    btn.disabled = false; btn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Login';
}

