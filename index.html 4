<script>
(function() {
    'use strict';

    // ===== LANGUAGE =====
    const langButtons = document.querySelectorAll('.lang-btn');
    let currentLang = 'en';
    function setLang(lang) {
        currentLang = lang;
        langButtons.forEach(btn => btn.classList.toggle('active', btn.getAttribute('data-lang') === lang));
        document.querySelectorAll('[data-en][data-ar]').forEach(el => {
            el.textContent = el.getAttribute(lang === 'en' ? 'data-en' : 'data-ar');
        });
        const si = document.getElementById('searchInput');
        if (si) si.placeholder = lang === 'en' ? 'Search Imam Malick Islamic Institute...' : 'البحث في معهد الإمام مالك الإسلامي...';
    }
    langButtons.forEach(btn => btn.addEventListener('click', () => setLang(btn.getAttribute('data-lang'))));
    setLang('en');

    // ===== TABS =====
    document.querySelectorAll('.tab-item').forEach(item => {
        item.addEventListener('click', () => {
            document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            item.classList.add('active');
            const pane = document.getElementById(item.dataset.tab);
            if (pane) pane.classList.add('active');
        });
    });

    // ===== CAROUSEL =====
    let currentSlideIndex = 0;
    const slides = document.querySelectorAll('.carousel-slide');
    const dots = document.querySelectorAll('.dot');
    function showSlide(index) {
        if (!slides.length) return;
        if (index >= slides.length) index = 0;
        if (index < 0) index = slides.length - 1;
        slides.forEach(s => s.classList.remove('active'));
        dots.forEach(d => d.classList.remove('active'));
        slides[index].classList.add('active');
        if (dots[index]) dots[index].classList.add('active');
        currentSlideIndex = index;
    }
    window.changeSlide = d => showSlide(currentSlideIndex + d);
    window.currentSlide = i => showSlide(i - 1);
    let slideInterval = setInterval(() => showSlide(currentSlideIndex + 1), 3800);
    const carousel = document.querySelector('.carousel-container');
    if (carousel) {
        carousel.addEventListener('mouseenter', () => clearInterval(slideInterval));
        carousel.addEventListener('mouseleave', () => {
            clearInterval(slideInterval);
            slideInterval = setInterval(() => showSlide(currentSlideIndex + 1), 3800);
        });
    }
    showSlide(0);

    // ===== SEARCH =====
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchDb = [
        { title:{en:'Home',ar:'الرئيسية'}, category:{en:'Home',ar:'الرئيسية'}, preview:{en:'Welcome to Imam Malick',ar:'مرحبا بكم'}, tab:'tab1', elementId:'welcome-section', keywords:['welcome','home','imam malick','مرحبا','الرئيسية'] },
        { title:{en:'Mission',ar:'مهمتنا'}, category:{en:'Home',ar:'الرئيسية'}, preview:{en:'Our mission & values',ar:'مهمتنا وقيمنا'}, tab:'tab1', elementId:'mission-section', keywords:['mission','مهمة','values','quran','sunnah'] },
        { title:{en:'Vision',ar:'رؤيتنا'}, category:{en:'Home',ar:'الرئيسية'}, preview:{en:'Our vision',ar:'رؤيتنا'}, tab:'tab1', elementId:'vision-section', keywords:['vision','رؤية','future','excellence'] },
        { title:{en:'About Us',ar:'عن المعهد'}, category:{en:'About',ar:'عن المعهد'}, preview:{en:'Learn about our institute',ar:'تعرف على معهدنا'}, tab:'tab2', elementId:'about-section', keywords:['about','imam malick','ibn anas','عن','تأسس'] },
        { title:{en:'Gambia Islamic Union',ar:'الاتحاد الإسلامي'}, category:{en:'About',ar:'عن المعهد'}, preview:{en:'Our union partnership',ar:'شراكتنا'}, tab:'tab2', elementId:'gambia-union-section', keywords:['union','gambia','islamic','اتحاد'] },
        { title:{en:'Admissions 2026',ar:'القبول ٢٠٢٦'}, category:{en:'Admission',ar:'القبول'}, preview:{en:'Apply for 2026 academic year',ar:'التقديم للعام ٢٠٢٦'}, tab:'tab3', elementId:'admission-section', keywords:['admission','apply','enroll','2026','قبول','تقديم'] },
        { title:{en:'Programmes',ar:'البرامج'}, category:{en:'Admission',ar:'القبول'}, preview:{en:'Our academic programmes',ar:'برامجنا الأكاديمية'}, tab:'tab3', elementId:'programs-section', keywords:['programmes','quran','fiqh','hadith','برامج'] },
        { title:{en:'News & Events',ar:'الأخبار'}, category:{en:'News',ar:'الأخبار'}, preview:{en:'Latest school news',ar:'آخر الأخبار'}, tab:'tab4', elementId:'news-section', keywords:['news','events','graduation','أخبار','تخرج'] },
        { title:{en:'Student Portal',ar:'بوابة الطالب'}, category:{en:'Portal',ar:'البوابة'}, preview:{en:'Access your results',ar:'عرض النتائج'}, tab:'tab5', elementId:'student-login', keywords:['student','login','portal','results','طالب','نتائج','دخول'] },
    ];
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const q = this.value.trim().toLowerCase();
            if (q.length < 2) { searchResults.classList.remove('active'); return; }
            const results = searchDb.filter(item => item.keywords.some(k => k.toLowerCase().includes(q))).slice(0, 5);
            if (results.length > 0) {
                searchResults.innerHTML = results.map(r =>
                    `<div class="search-result-item" data-tab="${r.tab||''}" data-element="${r.elementId||''}">
                        <div class="result-category"><i class="fas fa-tag"></i> ${r.category[currentLang]}</div>
                        <div class="result-title">${r.title[currentLang]}</div>
                        <div class="result-preview">${r.preview[currentLang]}</div>
                    </div>`
                ).join('');
                searchResults.classList.add('active');
                document.querySelectorAll('.search-result-item').forEach(item => {
                    item.addEventListener('click', function() {
                        const tabId = this.dataset.tab;
                        if (tabId) {
                            const tabItem = document.querySelector(`.tab-item[data-tab="${tabId}"]`);
                            if (tabItem) { tabItem.click(); setTimeout(() => scrollHighlight(this.dataset.element), 120); }
                        }
                        searchInput.value = ''; searchResults.classList.remove('active');
                    });
                });
            } else {
                searchResults.innerHTML = `<div class="no-results"><i class="fas fa-search"></i> No results found</div>`;
                searchResults.classList.add('active');
            }
        });
        document.addEventListener('click', e => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target))
                searchResults.classList.remove('active');
        });
        searchInput.addEventListener('keyup', function() { if (!this.value.trim()) searchResults.classList.remove('active'); });
    }
    function scrollHighlight(id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.scrollIntoView({ behavior:'smooth', block:'center' });
    }
})();

