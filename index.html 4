async function handlePhotoUpload(event) {
    var file = event.target.files[0];
    if (!file || !file.type.startsWith('image/')) return;
    showPhotoToast('Processing photo...', true);
    var reader = new FileReader();
    reader.onload = async function(e) {
        var img = new Image();
        img.onload = async function() {
            var canvas = document.createElement('canvas');
            var MAX = 200, w = img.width, h = img.height;
            if (w > h) { if (w > MAX) { h = Math.round(h*MAX/w); w = MAX; } }
            else { if (h > MAX) { w = Math.round(w*MAX/h); h = MAX; } }
            canvas.width = w; canvas.height = h;
            var ctx = canvas.getContext('2d');
            ctx.beginPath(); ctx.arc(w/2,h/2,Math.min(w,h)/2,0,Math.PI*2); ctx.closePath(); ctx.clip();
            ctx.drawImage(img, 0, 0, w, h);
            var dataUrl = canvas.toDataURL('image/jpeg', 0.7);
            setAvatarPhoto(dataUrl);
            showPhotoToast('Saving photo...', true);
            try {
                var res = await fetch('/api/upload-photo', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ studentId: currentStudentData.studentId || currentStudentData.student_id, photoDataUrl: dataUrl })
                });
                var data = await res.json();
                showPhotoToast(data.success ? '✓ Photo saved successfully' : '⚠ Save failed', false);
            } catch(err) { showPhotoToast('⚠ Connection error — photo shown locally only', false); }
        };
        img.src = e.target.result;
    };
    reader.readAsDataURL(file);
    event.target.value = '';
}

