function showTermReport(term, year) {
    var results = allStudentResults.filter(r => r.term === term && r.academic_year === year);
    var student = currentStudentData;
    results.sort(function(a,b) {
        var ai=SUBJECT_ORDER.indexOf(a.subject); var bi=SUBJECT_ORDER.indexOf(b.subject);
        if (ai===-1) ai=999; if (bi===-1) bi=999; return ai-bi;
    });
    var today = new Date();
    var dateStr = today.getDate()+'/'+(today.getMonth()+1)+'/'+today.getFullYear();
    var total = results.reduce((s,r) => s+(Number(r.score)||0), 0);
    var maxTotal = results.length * 100;
    var pct = maxTotal > 0 ? (total/maxTotal)*100 : 0;
    var gradeLabel = pct>=90?'Excellent':pct>=75?'Very Good':pct>=60?'Good':pct>=50?'Pass':'Weak';
    var gradeNames = {'10':'Grade 10','11':'Grade 11','12':'Grade 12'};
    var gradeStr = gradeNames[String(student.gradeLevel || student.grade_level)] || ('Grade '+(student.gradeLevel||student.grade_level||''));
    var classStr = (student.className || student.class_name) ? ' (Class '+(student.className||student.class_name)+')' : '';

    document.getElementById('reportStudentName').textContent = student.fullName || student.full_name;
    document.getElementById('reportClassName').textContent = gradeStr+classStr;
