// ===== LOGIN LOCKOUT =====
(function(){
    var attempts = parseInt(localStorage.getItem('imLoginAttempts')||'0');
    var lockUntil = parseInt(localStorage.getItem('imLockUntil')||'0');
    var origLogin = window.studentLogin;
    window.studentLogin = async function(){
        var now = Date.now();
        var errorEl = document.getElementById('student-login-error');
        var idInput = document.getElementById('student-id-input');
        var passInput = document.getElementById('student-pass-input');
        if(now < lockUntil){
            var mins = Math.ceil((lockUntil-now)/60000);
            errorEl.textContent = 'Account temporarily locked. Try again in '+mins+' minute(s).';
            errorEl.classList.add('show');
            idInput.classList.add('shake'); passInput.classList.add('shake');
            setTimeout(()=>{ idInput.classList.remove('shake'); passInput.classList.remove('shake'); }, 500);
            return;
        }
        await origLogin();
        var isError = errorEl.classList.contains('show');
        if(isError){
            attempts++;
            localStorage.setItem('imLoginAttempts', attempts);
            idInput.classList.add('shake'); passInput.classList.add('shake');
            setTimeout(()=>{
                idInput.classList.remove('shake'); passInput.classList.remove('shake');
                idInput.value=''; passInput.value=''; idInput.focus();
            }, 500);
            if(attempts >= 5){
                var until = Date.now() + 30*60*1000;
                localStorage.setItem('imLockUntil', until);
                localStorage.setItem('imLoginAttempts', '0');
                attempts = 0;
                errorEl.textContent = 'Too many failed attempts. Account locked for 30 minutes.';
                errorEl.classList.add('show');
            }
        } else {
            localStorage.setItem('imLoginAttempts', '0');
            localStorage.setItem('imLockUntil', '0');
            attempts = 0;
        }
    };
})();
// Hidden admin access via secret URL hash
function checkAdminHash() {
    if (window.location.hash === '#imammalick-admin') {
        openAdminModal();
        history.replaceState(null, '', window.location.pathname);
    }
}
window.addEventListener('hashchange', checkAdminHash);
window.addEventListener('load', checkAdminHash);
</script>
