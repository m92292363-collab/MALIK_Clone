async function loadTopStudents() {
    const year = document.getElementById('top-year').value.trim();
    const term = document.getElementById('top-term').value;
    const grade = document.getElementById('top-grade').value;
    const limit = parseInt(document.getElementById('top-limit').value);
    const tbody = document.getElementById('topStudentsBody');
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:2rem;"><i class="fas fa-spinner fa-spin" style="color:var(--accent-gold);font-size:1.5rem;"></i></td></tr>';
    try {
        const params = [];
        if (year) params.push('academicYear=' + encodeURIComponent(year));
        if (term) params.push('term=' + encodeURIComponent(term));
        if (grade) params.push('gradeLevel=' + encodeURIComponent(grade));
        const res = await fetch('/api/get-all-results' + (params.length ? '?' + params.join('&') : ''));
        const data = await res.json();
        if (!data.success) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#c0392b;">Failed to load</td></tr>'; return; }
        const byStudent = {};
        data.results.forEach(r => {
            if (!byStudent[r.student_id]) byStudent[r.student_id] = { name: r.full_name, grade: r.grade_level, cls: r.class_name, total: 0, count: 0 };
            byStudent[r.student_id].total += Number(r.score || 0);
            byStudent[r.student_id].count++;
        });
        const sorted = Object.entries(byStudent).sort((a,b) => b[1].total - a[1].total).slice(0, limit);
        if (!sorted.length) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#999;">No results found</td></tr>'; return; }
        const medals = ['🥇','🥈','🥉'];
        tbody.innerHTML = sorted.map(([id, s], i) => {
            const avg = (s.total / s.count).toFixed(1);
            const color = avg >= 75 ? '#2e7d32' : avg >= 50 ? '#f57f17' : '#c0392b';
            return `<tr><td style="font-weight:800;font-size:1.1rem;">${medals[i] || (i+1)}</td><td style="font-weight:700;color:#1565c0;">${id}</td><td>${s.name}</td><td>Grade ${s.grade||'-'}</td><td>${s.cls||'-'}</td><td style="font-weight:700;">${s.total}</td><td style="font-weight:700;color:${color};">${avg}%</td></tr>`;
        }).join('');
    } catch(err) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#c0392b;">Connection error</td></tr>'; }
}

