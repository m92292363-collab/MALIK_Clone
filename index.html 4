    document.getElementById('attestationText').innerHTML =
        `The administration of Imam Malick Islamic Institute certifies that the student: <strong>${student.fullName||student.full_name}</strong> has successfully completed ${term} examinations for the academic year <strong>${year}</strong> with overall grade: <strong>${gradeLabel}</strong>.`;
    document.getElementById('reportRank').textContent = '...';
    document.getElementById('reportClassCount').textContent = '...';
    document.getElementById('reportGradeLabel').textContent = gradeLabel;
    document.getElementById('reportPassCount').textContent = '...';

    fetch(`/api/get-class-stats?gradeLevel=${student.gradeLevel||student.grade_level}&className=${encodeURIComponent(student.className||student.class_name||'')}&term=${encodeURIComponent(term)}&academicYear=${encodeURIComponent(year)}&studentId=${encodeURIComponent(student.studentId||student.student_id)}`)
