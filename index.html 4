    });
    rows += `<tr><td colspan="2"><strong>Grand Total</strong></td><td>${maxTotal}</td><td>${results.length*50}</td><td><strong>${total}</strong></td><td>${toWords(total)}</td><td>&nbsp;</td></tr>`;
