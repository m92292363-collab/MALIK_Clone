}

function scaleA4ToCanvas() {
    // FIX: use requestAnimationFrame to ensure layout is complete
    requestAnimationFrame(function() {
        var canvas = document.getElementById('reportCanvas');
        var sheet = document.getElementById('a4Report');
        if (!canvas || !sheet) return;
        sheet.style.transform = 'scale(1)';
        sheet.style.marginBottom = '0';
        requestAnimationFrame(function() {
            var canvasW = canvas.clientWidth - 48;
            var sheetW = sheet.offsetWidth;
            if (sheetW <= 0) return;
            var scale = Math.min(1, canvasW / sheetW);
            sheet.style.transform = 'scale(' + scale + ')';
            // FIX: correct margin calculation to avoid layout collapse
            var scaledHeight = sheet.offsetHeight * scale;
            var naturalHeight = sheet.offsetHeight;
            sheet.style.marginBottom = '-' + Math.max(0, naturalHeight - scaledHeight - 24) + 'px';
        });
    });
}

