<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Imam Malick Islamic Institute · Excellence in Islamic Education</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        :root {
            --primary-dark: #0d3b6e;
            --primary-blue: #1565c0;
            --primary-mid: #1976d2;
            --accent-gold: #e53935;
            --accent-light: #ef5350;
            --accent-glow: rgba(229,57,53,0.4);
            --text-dark: #0d2a4a;
            --text-soft: #1a4a7a;
            --text-light: #2e6da0;
            --bg-soft: #e8f4fd;
            --bg-blue-soft: #bbdefb;
            --islamic-blue: #1565c0;
            --footer-bg: #0d2a4a;
            --footer-text: #e3f2fd;
            --footer-heading: #ef5350;
            --facebook-color: #1877f2;
            --instagram-color: #e4405f;
            --youtube-color: #ff0000;
            --card-bg: #e3f2fd;
            --card-bg-mid: #bbdefb;
            --card-border: rgba(21,101,192,0.18);
        }
        html { font-size: 16px; scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
        body {
            background: linear-gradient(160deg, #e3f2fd 0%, #bbdefb 40%, #e1f5fe 100%);
            background-attachment: fixed;
            color: var(--text-dark);
            font-family: 'Nunito', sans-serif;
            line-height: 1.5;
            overflow-x: hidden;
            width: 100%;
            -webkit-font-smoothing: antialiased;
        }
        .container { max-width: 1280px; margin: 0 auto; padding: 0 1rem; width: 100%; }
        button, a { touch-action: manipulation; cursor: pointer; }

        /* ===== NAVBAR ===== */
        .navbar {
            display: flex; align-items: center; justify-content: space-between;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-radius: 0 0 20px 20px;
            padding: 0.85rem 1.4rem;
            box-shadow: 0 3px 22px rgba(21,101,192,0.13);
            border-bottom: 2px solid rgba(21,101,192,0.12);
            margin-bottom: 0.6rem;
            gap: 0.8rem;
            flex-wrap: nowrap;
        }
        .nav-left { display: flex; align-items: center; flex-shrink: 0; }
        .lang-switch {
            display: flex; align-items: center; gap: 0.2rem;
            background: var(--bg-blue-soft); padding: 0.15rem;
            border-radius: 30px;
        }
        .lang-switch button {
            background: transparent; border: none;
            padding: 0.3rem 0.85rem; border-radius: 30px;
            font-size: 0.82rem; font-weight: 700;
            cursor: pointer; color: var(--text-dark); transition: all 0.2s;
            font-family: 'Nunito', sans-serif; white-space: nowrap;
        }
        .lang-switch button.active { background: var(--islamic-blue) !important; color: white !important; }
        .nav-center { display: flex; align-items: center; gap: 0.75rem; flex: 1; justify-content: center; min-width: 0; }
        .school-logo {
            width: 62px; height: 62px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #1565c0, #42a5f5);
            border-radius: 50%;
            border: 3px solid var(--accent-gold);
            box-shadow: 0 4px 18px rgba(21,101,192,0.3);
        }
        .school-logo i { font-size: 2rem; color: var(--accent-gold); line-height: 1; }
        .institute-name {
            font-family: 'Amiri', serif;
            font-size: 1.45rem; font-weight: 700;
            color: var(--islamic-blue);
            letter-spacing: 0.4px;
            line-height: 1.2;
            min-width: 0;
        }
        .institute-name .sub { font-size: 0.78rem; color: var(--accent-gold); font-family: 'Nunito', sans-serif; font-weight: 700; display: block; letter-spacing: 1.8px; text-transform: uppercase; }
        .nav-right { display: flex; align-items: center; flex-shrink: 0; }
        /* Admin access - subtle hidden button */
        .admin-trigger {
            background: none; border: 1.5px dashed rgba(21,101,192,0.3);
            color: var(--text-light); padding: 0.3rem 0.7rem;
            border-radius: 20px; font-size: 0.72rem; font-weight: 700;
            cursor: pointer; transition: all 0.2s;
            display: flex; align-items: center; gap: 0.35rem;
            font-family: 'Nunito', sans-serif;
        }
        .admin-trigger:hover { border-color: var(--accent-gold); color: var(--accent-gold); background: rgba(229,57,53,0.06); }
        .admin-trigger i { font-size: 0.68rem; }

        /* ===== SEARCH ===== */
        .search-section { margin: 0.2rem 0 0.8rem; width: 100%; display: flex; justify-content: center; position: relative; z-index: 1000; }
        .search-container { width: 75%; max-width: 340px; margin: 0 auto; position: relative; }
        .search-wrapper {
            position: relative; display: flex; align-items: center;
            background: white; border-radius: 30px;
            border: 1.5px solid #90caf9; transition: all 0.2s;
            height: 40px; box-shadow: 0 2px 12px rgba(21,101,192,0.10);
        }
        .search-wrapper:focus-within { border-color: var(--accent-gold); box-shadow: 0 0 0 3px rgba(229,57,53,0.14); }
        .search-icon { position: absolute; left: 13px; color: #64b5f6; font-size: 0.85rem; pointer-events: none; }
        .search-wrapper:focus-within .search-icon { color: var(--accent-gold); }
        .search-input {
            width: 100%; height: 100%; padding: 0 12px 0 36px;
            border: none; border-radius: 30px; font-size: 14px;
            background: transparent; outline: none; color: var(--text-dark);
            font-family: 'Nunito', sans-serif;
        }
        .search-input::placeholder { color: #90caf9; }
        .search-results {
            position: absolute; top: calc(100% + 6px); left: 0; right: 0;
            background: white; border-radius: 15px;
            box-shadow: 0 10px 28px rgba(21,101,192,0.18);
            max-height: 380px; overflow-y: auto; display: none;
            z-index: 1001; border: 1px solid #bbdefb;
        }
        .search-results.active { display: block; }
        .search-result-item { padding: 11px 15px; border-bottom: 1px solid #e3f2fd; cursor: pointer; transition: background 0.2s; }
        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover { background: #e3f2fd; }
        .search-result-item .result-title { font-weight: 700; color: var(--islamic-blue); margin-bottom: 3px; font-size: 13.5px; }
        .search-result-item .result-category { font-size: 11px; color: var(--accent-gold); margin-bottom: 3px; font-weight: 700; text-transform: uppercase; }
        .search-result-item .result-preview { font-size: 12px; color: var(--text-light); }
        .no-results { padding: 20px; text-align: center; color: var(--text-light); font-size: 14px; }

        /* ===== TABS ===== */
        .tabs-section {
            margin: 0.2rem 0 1.5rem;
            background: rgba(255,255,255,0.80);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 18px;
            box-shadow: 0 4px 24px rgba(21,101,192,0.12);
            overflow: hidden;
            border: 1px solid rgba(144,202,249,0.4);
        }
        .tabs-header {
            background: linear-gradient(90deg, #1565c0, #1976d2, #42a5f5);
            overflow-x: auto; overflow-y: hidden;
            white-space: nowrap; -webkit-overflow-scrolling: touch;
            scrollbar-width: none; display: flex; align-items: stretch;
            justify-content: center; width: 100%;
        }
        .tabs-header::-webkit-scrollbar { display: none; }
        .tab-item {
            display: inline-flex; align-items: center; justify-content: center;
            padding: 0.8rem 1.2rem; font-size: 0.87rem; font-weight: 700;
            color: rgba(255,255,255,0.88);
            border-bottom: 3px solid transparent;
            cursor: pointer; transition: all 0.22s;
            white-space: nowrap; gap: 0.4rem;
            flex: 0 0 auto; font-family: 'Nunito', sans-serif;
        }
        .tab-item i { font-size: 0.85rem; }
        .tab-item:hover { background: rgba(255,255,255,0.14); color: white; }
        .tab-item.active {
            color: var(--islamic-blue);
            border-bottom-color: var(--accent-gold);
            background: rgba(255,255,255,0.96); font-weight: 800;
        }
        .tab-item.active i { color: var(--accent-gold); }
        .tab-content { padding: 1.5rem 0 0; }
        .tab-pane { display: none; }
        .tab-pane.active { display: block; }

        /* ===== CAROUSEL ===== */
        .carousel-box { background: #e3f2fd; overflow: hidden; border-top: 1px solid #90caf9; }
        .carousel-container { position: relative; width: 100%; overflow: hidden; }
        .carousel-slides { position: relative; width: 100%; height: 0; padding-bottom: 45%; background: #bbdefb; min-height: 220px; }
        .carousel-slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; visibility: hidden; transition: opacity 1.4s ease-in-out, visibility 1.4s; z-index: 1; }
        .carousel-slide.active { opacity: 1; visibility: visible; z-index: 2; }
        .image-container { position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
        .image-container img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .slide-placeholder {
            width: 100%; height: 100%;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            background: linear-gradient(135deg, #1565c0, #42a5f5);
            color: white; text-align: center; padding: 2rem;
        }
        .slide-placeholder i { font-size: 3.5rem; color: var(--accent-gold); margin-bottom: 1rem; }
        .slide-placeholder h3 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.4rem; font-family: 'Amiri', serif; }
        .slide-placeholder p { opacity: 0.82; font-size: 1rem; }
        .carousel-dots { display: flex; justify-content: center; gap: 0.5rem; padding: 0.75rem; background: rgba(255,255,255,0.65); border-top: 1px solid #bbdefb; }
        .dot { width: 10px; height: 10px; border-radius: 50%; background: #90caf9; cursor: pointer; transition: all 0.3s; border: none; }
        .dot.active { background: var(--accent-gold); transform: scale(1.35); }
        .carousel-arrow {
            position: absolute; top: 50%; transform: translateY(-50%);
            width: 38px; height: 38px; background: rgba(21,101,192,0.5);
            color: white; border: none; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 20; transition: all 0.3s; font-size: 1rem;
        }
        .carousel-arrow:hover { background: rgba(21,101,192,0.85); }
        .carousel-arrow.prev { left: 12px; }
        .carousel-arrow.next { right: 12px; }

        /* ===== WELCOME ===== */
        .welcome-section { background: linear-gradient(135deg, #1565c0, #1e88e5); padding: 3rem 1rem; }
        .welcome-card {
            max-width: 1000px; margin: 0 auto; background: rgba(255,255,255,0.97);
            border-radius: 2rem; padding: 2.5rem 2rem;
            box-shadow: 0 20px 60px -15px rgba(21,101,192,0.4);
            border: 1px solid rgba(229,57,53,0.2); position: relative; overflow: hidden;
        }
        .welcome-card::before {
            content: 'بِسْمِ اللَّهِ';
            font-family: 'Amiri', serif;
            position: absolute; top: -5px; right: -10px;
            font-size: 100px; color: rgba(21,101,192,0.06);
            transform: rotate(10deg); pointer-events: none;
        }
        .welcome-content { position: relative; z-index: 2; text-align: center; }
        .welcome-title {
            font-family: 'Amiri', serif;
            font-size: 2.1rem; color: var(--islamic-blue);
            margin-bottom: 2rem; font-weight: 700;
            position: relative; display: inline-block;
        }
        .welcome-title::after {
            content: ''; position: absolute; bottom: -10px; left: 50%;
            transform: translateX(-50%); width: 60px; height: 3px;
            background: var(--accent-gold); border-radius: 2px;
        }
        .welcome-text { max-width: 800px; margin: 0 auto; }
        .welcome-text p { color: var(--text-dark); line-height: 1.9; margin-bottom: 1.5rem; font-size: 1.08rem; text-align: center; padding: 0 1rem; }
        .welcome-text p:first-of-type { font-weight: 600; border-bottom: 2px solid rgba(21,101,192,0.12); padding-bottom: 1.5rem; }
        .welcome-decoration { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 2rem; }
        .welcome-decoration i { color: var(--accent-gold); font-size: 1.1rem; opacity: 0.6; }

        /* ===== MISSION ===== */
        .mission-card-home { background: linear-gradient(145deg, #1565c0 0%, #1e88e5 100%); color: white; padding: 3.5rem 1rem; text-align: center; border-top: 1px solid rgba(144,202,249,0.3); }
        .mission-content { max-width: 900px; margin: 0 auto; padding: 0 1rem; }
        .mission-card-home h3 { font-family: 'Amiri', serif; font-size: 2.2rem; margin-bottom: 2.5rem; color: white; font-weight: 700; position: relative; display: inline-block; }
        .mission-card-home h3::after { content: ''; position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); width: 80px; height: 3px; background: var(--accent-gold); border-radius: 2px; }
        .mission-list-home { list-style: none; display: flex; flex-direction: column; gap: 1.2rem; max-width: 800px; margin: 0 auto; }
        .mission-list-home li { display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 0.5rem 1rem; font-size: 1.1rem; border-bottom: 1px solid rgba(255,255,255,0.15); }
        .mission-list-home li:last-child { border-bottom: none; }
        .mission-list-home i { color: var(--accent-gold); font-size: 1.2rem; flex-shrink: 0; }

        /* ===== VISION ===== */
        .vision-card-home { background: linear-gradient(145deg, #0d3b6e 0%, #1565c0 100%); color: white; padding: 3.5rem 1rem; text-align: center; border-top: 1px solid rgba(229,57,53,0.25); }
        .vision-content { max-width: 900px; margin: 0 auto; padding: 0 1rem; }
        .vision-card-home h3 { font-family: 'Amiri', serif; font-size: 2.2rem; margin-bottom: 2.5rem; color: white; font-weight: 700; position: relative; display: inline-block; }
        .vision-card-home h3::after { content: ''; position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); width: 80px; height: 3px; background: var(--accent-gold); border-radius: 2px; }
        .vision-text { display: flex; flex-direction: column; gap: 1.5rem; }
        .vision-main { font-size: 1.25rem; line-height: 1.8; font-weight: 600; max-width: 800px; margin: 0 auto; }
        .vision-middle { font-size: 1.08rem; line-height: 1.7; max-width: 750px; margin: 0 auto; border-top: 1px solid rgba(229,57,53,0.3); border-bottom: 1px solid rgba(229,57,53,0.3); padding: 1.5rem 1rem; }
        .vision-last { font-size: 1.05rem; line-height: 1.7; max-width: 750px; margin: 0 auto; opacity: 0.85; font-style: italic; }

        /* ===== ABOUT ===== */
        .about-section { background: linear-gradient(135deg, rgba(255,255,255,0.88), rgba(227,242,253,0.88)); border-radius: 1.5rem; padding: 3rem 2rem; margin: 1rem 0; box-shadow: 0 15px 40px -10px rgba(21,101,192,0.14); border: 1px solid rgba(144,202,249,0.4); text-align: center; position: relative; overflow: hidden; }
        .about-section::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--accent-gold), #1565c0, var(--accent-gold)); }
        .about-content { max-width: 800px; margin: 0 auto; position: relative; z-index: 2; }
        .about-content h2 { font-family: 'Amiri', serif; font-size: 2rem; color: var(--islamic-blue); margin-bottom: 2rem; font-weight: 700; position: relative; display: inline-block; }
        .about-content h2 i { color: var(--accent-gold); margin-right: 0.5rem; }
        .about-content h2::after { content: ''; position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); width: 60px; height: 3px; background: var(--accent-gold); border-radius: 2px; }
        .about-content p { color: var(--text-dark); line-height: 1.9; margin-bottom: 1.5rem; font-size: 1.08rem; font-weight: 600; }
        .about-highlight { background: linear-gradient(145deg, #1565c0, #1e88e5); padding: 2rem; border-radius: 1rem; margin-top: 2rem; color: white; box-shadow: 0 10px 30px -8px rgba(21,101,192,0.4); }
        .about-highlight p { color: white; font-size: 1.15rem; font-weight: 700; margin: 0; }

        /* ===== GAMBIA UNION ===== */
        .gambia-union-card { background: linear-gradient(135deg, #fff9e6, #e3f2fd); border-radius: 1.5rem; padding: 2.5rem; margin: 2rem auto; border: 3px solid var(--accent-gold); text-align: center; max-width: 800px; position: relative; overflow: hidden; box-shadow: 0 20px 45px -10px rgba(229,57,53,0.18); }
        .union-icon { width: 90px; height: 90px; background: linear-gradient(135deg, #1565c0, #42a5f5); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--accent-gold); font-size: 2.6rem; border: 4px solid var(--accent-gold); box-shadow: 0 10px 25px rgba(21,101,192,0.28); }
        .gambia-union-card h3 { font-family: 'Amiri', serif; color: var(--islamic-blue); font-size: 1.9rem; margin-bottom: 0.5rem; font-weight: 800; }
        .gambia-union-card h4 { color: var(--accent-gold); font-size: 1.1rem; margin-bottom: 2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-bottom: 2px solid rgba(229,57,53,0.28); padding-bottom: 0.8rem; display: inline-block; }
        .union-flags { display: flex; align-items: center; justify-content: center; gap: 2rem; margin: 2rem 0; flex-wrap: wrap; }
        .flag-item { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
        .flag-item i { font-size: 2.2rem; color: var(--accent-gold); }
        .flag-item span { font-size: 0.9rem; font-weight: 700; color: var(--text-dark); background: white; padding: 0.3rem 0.9rem; border-radius: 30px; border: 2px solid var(--accent-gold); }
        .union-description { font-size: 1.05rem; line-height: 1.8; color: var(--text-dark); max-width: 600px; margin: 2rem auto; font-weight: 500; background: rgba(255,255,255,0.9); padding: 1.2rem 2rem; border-radius: 60px; border: 1px solid rgba(229,57,53,0.25); }
        .union-badge { display: inline-flex; align-items: center; gap: 0.8rem; background: var(--accent-gold); color: #1a2a4a; padding: 0.8rem 2rem; border-radius: 50px; font-weight: 800; font-size: 0.95rem; margin-top: 1.5rem; box-shadow: 0 8px 20px rgba(229,57,53,0.3); }

        /* ===== ADMISSION ===== */
        .admission-section { background: rgba(255,255,255,0.82); border-radius: 1.5rem; padding: 2.5rem; margin: 1rem 0; box-shadow: 0 10px 30px -10px rgba(21,101,192,0.12); border: 1px solid rgba(144,202,249,0.35); }
        .admission-header { text-align: center; margin-bottom: 2.5rem; }
        .admission-header h2 { font-family: 'Amiri', serif; font-size: 2rem; color: var(--islamic-blue); margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
        .admission-header h2 i { color: var(--accent-gold); }
        .admission-header p { color: var(--text-light); font-size: 1.05rem; max-width: 700px; margin: 0 auto; line-height: 1.8; }
        .programs-card, .documents-card { background: linear-gradient(145deg, #e3f2fd, #bbdefb); border-radius: 1rem; padding: 2.5rem; margin-bottom: 2rem; border: 1px solid rgba(21,101,192,0.14); max-width: 800px; margin-left: auto; margin-right: auto; transition: transform 0.3s, box-shadow 0.3s; }
        .programs-card:hover, .documents-card:hover { transform: translateY(-4px); box-shadow: 0 15px 35px -10px rgba(21,101,192,0.2); border-color: var(--accent-gold); }
        .requirement-icon { width: 68px; height: 68px; background: linear-gradient(135deg, #1565c0, #42a5f5); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--accent-gold); font-size: 1.7rem; border: 3px solid var(--accent-gold); }
        .programs-card h3, .documents-card h3 { font-family: 'Amiri', serif; color: var(--islamic-blue); font-size: 1.55rem; margin-bottom: 1.5rem; font-weight: 700; text-align: center; }
        .programs-list { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; margin-top: 1rem; }
        .program-tag { background: white; padding: 0.65rem 0.8rem; border-radius: 30px; font-size: 0.88rem; color: var(--text-dark); border: 1px solid rgba(21,101,192,0.18); display: flex; align-items: center; justify-content: center; gap: 0.4rem; transition: all 0.2s; }
        .program-tag i { color: var(--accent-gold); font-size: 0.65rem; }
        .program-tag:hover { background: var(--islamic-blue); color: white; }
        .documents-list { list-style: none; text-align: center; margin-top: 1rem; }
        .documents-list li { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 1.1rem; color: var(--text-light); font-size: 1rem; padding: 0.5rem; border-bottom: 1px solid rgba(21,101,192,0.1); }
        .documents-list li:last-child { border-bottom: none; }
        .documents-list li i { color: var(--accent-gold); }
        .deadline-box { background: linear-gradient(135deg, #e3f2fd, #bbdefb); border-radius: 1rem; padding: 2rem; margin: 2rem auto; border: 2px dashed var(--accent-gold); text-align: center; max-width: 800px; }
        .deadline-box h4 { color: var(--islamic-blue); font-size: 1.35rem; margin-bottom: 0.5rem; font-family: 'Amiri', serif; }
        .deadline-box .date { color: var(--accent-gold); font-size: 1.75rem; font-weight: 800; margin: 1rem 0; }
        .deadline-box p { color: var(--text-dark); font-size: 0.98rem; }
        .apply-button { text-align: center; margin-top: 2rem; }
        .apply-button .btn { background: linear-gradient(145deg, #1565c0, #1e88e5); color: white; padding: 1rem 2.8rem; font-size: 1.08rem; border-radius: 50px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.8rem; transition: all 0.3s; border: 2px solid var(--accent-gold); font-weight: 700; font-family: 'Nunito', sans-serif; }
